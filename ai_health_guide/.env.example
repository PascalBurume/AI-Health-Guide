# MedGemma via Ollama (run `ollama pull medgemma` before starting)
MEDGEMMA_MODEL_NAME=medgemma          # exact tag shown by `ollama list`
MEDGEMMA_OLLAMA_BASE_URL=http://localhost:11434
MEDGEMMA_MAX_TOKENS=2048
MEDGEMMA_TEMPERATURE=0.3

# OpenAI (voice features only)
OPENAI_API_KEY=your_openai_api_key_here
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=nova

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Session limits
MAX_QUESTIONING_TURNS=15
MAX_SESSION_DURATION_MINUTES=30

# Supported languages
SUPPORTED_LANGUAGES=["en","fr","ja","ar","sw","es"]
DEFAULT_CLINICAL_LANGUAGE=en
